{
  "name": "auto-reply-discord-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "railway:build": "PLAYWRIGHT_BROWSERS_PATH=0 playwright install --with-deps chromium && npm run build",
    "railway:start": "PLAYWRIGHT_BROWSERS_PATH=0 npm run start",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "playwright": "^1.61.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
