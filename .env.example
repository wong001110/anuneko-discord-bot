DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# Use "session" with an AnuNeko browser session token.
# Use "direct" if you already have a chat token and message endpoint.
# Use "auto" for a generic login/create-chat API.
ANUNEKO_MODE=session

# Session mode
ANUNEKO_SESSION_TOKEN=
ANUNEKO_BASE_URL=https://anuneko.com

# Direct mode
ANUNEKO_TOKEN=
# ANUNEKO_BASE_URL=https://example.com/anuneko/chat

# Auto mode
ANUNEKO_LOGIN_URL=
ANUNEKO_CREATE_CHAT_URL=
ANUNEKO_LOGIN_ID=
ANUNEKO_PASSWORD=
ANUNEKO_LOGIN_ID_FIELD=email
ANUNEKO_PASSWORD_FIELD=password
ANUNEKO_MESSAGE_URL_TEMPLATE=
ANUNEKO_CREATE_CHAT_BODY=

BOT_ALLOWED_CHANNEL_IDS=
BOT_ENABLE_MENTION_REPLIES=false

# Optional tuning
BOT_COOLDOWN_MS=7000
BOT_MAX_MESSAGE_LENGTH=500
ANUNEKO_TIMEOUT_MS=30000
